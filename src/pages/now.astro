---
import SiteLayout from "../components/SiteLayout.astro";
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<SiteLayout title="Now | Rodrigo Santos Tech" current="now">
  <style>
    .shell {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: rgba(8, 20, 32, 0.84);
      padding: 1.8rem;
      box-shadow: 0 20px 44px var(--shadow);
    }

    h1 {
      font-family: "Syne", sans-serif;
      margin: 0;
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.05;
    }

    p,
    li {
      color: #d8e6f8;
      line-height: 1.75;
    }

    ul {
      margin: 0.8rem 0 0;
      padding-left: 1.2rem;
    }

    .home {
      display: inline-flex;
      margin-top: 1rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 700;
    }

    .home:hover {
      text-decoration: underline;
    }
  </style>

  <section class="shell">
    <h1>Now</h1>
    <p>Atualmente focado em três frentes:</p>
    <ul>
      <li>Confiabilidade de plataformas com alto volume de integrações.</li>
      <li>Redução de lead time com automação de documentação técnica.</li>
      <li>Padronização de postmortems orientados a aprendizado sistêmico.</li>
    </ul>
    <a class="home" href={basePath}>Voltar para início</a>
  </section>
</SiteLayout>
