---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Now | Rodrigo Santos Tech</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #07101d;
        --line: rgba(116, 160, 224, 0.34);
        --ink: #ecf4ff;
        --muted: #a4bada;
        --accent: #36d2ff;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 78% 12%, rgba(54, 210, 255, 0.2) 0%, transparent 30%),
          linear-gradient(120deg, rgba(9, 28, 48, 0.96) 0%, rgba(4, 11, 19, 1) 55%, rgba(7, 16, 29, 1) 100%),
          var(--bg);
      }

      a {
        color: inherit;
      }

      main {
        width: min(760px, 92vw);
        margin: 0 auto;
        padding: 2.8rem 0 4rem;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 1.1rem;
        margin-bottom: 1.2rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(8, 19, 31, 0.72);
        backdrop-filter: blur(10px);
        box-shadow: 0 16px 32px rgba(3, 12, 18, 0.24);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
      }

      .brand-mark {
        width: 2.45rem;
        height: 2.45rem;
        display: grid;
        place-items: center;
        border-radius: 16px;
        background: linear-gradient(135deg, #79e7ff 0%, #36d2ff 100%);
        color: #06111c;
        font-family: "Chakra Petch", sans-serif;
        font-weight: 700;
      }

      .brand-copy {
        display: grid;
        gap: 0.05rem;
      }

      .brand-title {
        font-family: "Chakra Petch", sans-serif;
        font-size: 0.98rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .brand-subtitle {
        font-size: 0.76rem;
        color: var(--muted);
      }

      .menu {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: wrap;
      }

      .menu a {
        text-decoration: none;
        color: var(--muted);
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.5rem 0.85rem;
        font-family: "Chakra Petch", sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
      }

      .menu a:hover,
      .menu a[aria-current="page"] {
        color: var(--ink);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.04);
      }

      .shell {
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(10, 24, 42, 0.86);
        padding: 1.8rem;
      }

      h1 {
        font-family: "Chakra Petch", sans-serif;
        margin: 0;
        font-size: clamp(1.9rem, 4.5vw, 2.8rem);
      }

      p, li {
        color: #d8e6f8;
        line-height: 1.75;
      }

      ul {
        margin: 0.8rem 0 0;
        padding-left: 1.2rem;
      }

      .home {
        display: inline-flex;
        margin-top: 1rem;
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      @media (max-width: 640px) {
        .topbar {
          border-radius: 28px;
          align-items: flex-start;
          flex-direction: column;
        }

        .menu {
          width: 100%;
        }

        .menu a {
          flex: 1 1 auto;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topbar">
        <a class="brand" href={basePath}>
          <span class="brand-mark">RS</span>
          <span class="brand-copy">
            <span class="brand-title">Rodrigo Santos Tech</span>
            <span class="brand-subtitle">software, arquitetura e incidentes reais</span>
          </span>
        </a>

        <nav class="menu" aria-label="principal">
          <a href={`${basePath}about/`}>About</a>
          <a href={`${basePath}projects/`}>Projects</a>
          <a href={`${basePath}#posts`}>Posts</a>
        </nav>
      </header>

      <section class="shell">
        <h1>Now</h1>
        <p>Atualmente focado em três frentes:</p>
        <ul>
          <li>Confiabilidade de plataformas com alto volume de integrações.</li>
          <li>Redução de lead time com automação de documentação técnica.</li>
          <li>Padronização de postmortems orientados a aprendizado sistêmico.</li>
        </ul>
        <a class="home" href={basePath}>Voltar para início</a>
      </section>
    </main>
  </body>
</html>
