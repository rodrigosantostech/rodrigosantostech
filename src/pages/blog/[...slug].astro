---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import SiteLayout from "../../components/SiteLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<SiteLayout title={post.data.title} current="posts">
  <style>
    .article-shell {
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 1.8rem;
      background: linear-gradient(155deg, rgba(12, 29, 49, 0.96), rgba(6, 16, 29, 0.92));
      box-shadow: 0 24px 48px var(--shadow);
    }

    h1 {
      font-family: "Syne", sans-serif;
      font-size: clamp(2rem, 5vw, 3.1rem);
      line-height: 1.05;
      margin: 0;
    }

    .meta {
      color: var(--muted);
      margin: 0.9rem 0 1.6rem;
      line-height: 1.6;
    }

    .meta strong {
      color: var(--accent-2);
      font-family: "Syne", sans-serif;
    }

    :global(.prose h2) {
      font-family: "Syne", sans-serif;
      font-size: clamp(1.4rem, 3vw, 1.8rem);
      margin: 2.2rem 0 0.6rem;
      line-height: 1.2;
    }

    :global(.prose p),
    :global(.prose li) {
      color: #d8e6f8;
      line-height: 1.78;
      font-size: 1.03rem;
    }

    :global(.prose ul) {
      padding-left: 1.2rem;
    }

    :global(.prose a) {
      color: var(--accent);
    }

    .back {
      display: inline-flex;
      margin-top: 1.8rem;
      text-decoration: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.55rem 0.9rem;
      color: #f6fbff;
      transition: transform 150ms ease, border-color 150ms ease, color 150ms ease;
    }

    .back:hover {
      color: var(--accent);
      border-color: var(--accent);
      transform: translateY(-2px);
    }

    @media (max-width: 640px) {
      .article-shell {
        padding: 1.2rem;
      }
    }
  </style>

  <article class="article-shell">
    <h1>{post.data.title}</h1>
    <p class="meta">
      <strong>{post.data.pubDate.toLocaleDateString("pt-BR")}</strong> - {post.data.description}
    </p>
    <div class="prose">
      <Content />
    </div>
    <a class="back" href={basePath}>Voltar para a home</a>
  </article>
</SiteLayout>
