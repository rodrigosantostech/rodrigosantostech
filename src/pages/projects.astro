---
import SiteLayout from "../components/SiteLayout.astro";
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<SiteLayout title="Projects | Rodrigo Santos Tech" current="projects">
  <style>
    .shell {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: rgba(8, 20, 32, 0.84);
      padding: 1.8rem;
      box-shadow: 0 20px 44px var(--shadow);
    }

    h1 {
      font-family: "Syne", sans-serif;
      margin: 0;
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.05;
    }

    p,
    li {
      color: #d8e6f8;
      line-height: 1.75;
    }

    .project-list {
      list-style: none;
      padding: 0;
      margin: 1.2rem 0 0;
      display: grid;
      gap: 1rem;
    }

    .project-card {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(9, 19, 31, 0.9);
      padding: 1rem 1.1rem;
    }

    .project-card strong {
      display: block;
      margin-bottom: 0.35rem;
      font-family: "Syne", sans-serif;
      font-size: 1.08rem;
    }

    .project-meta {
      margin: 0.35rem 0 0;
      color: var(--muted);
    }

    .project-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 0.85rem;
    }

    .project-link,
    .home {
      color: var(--accent);
      text-decoration: none;
      font-weight: 700;
    }

    .project-link:hover,
    .home:hover {
      text-decoration: underline;
    }

    .home {
      display: inline-flex;
      margin-top: 1rem;
    }
  </style>

  <section class="shell">
    <h1>Projects</h1>
    <p>Projetos que conectam conteúdo técnico com prática em código.</p>
    <ul class="project-list">
      <li class="project-card">
        <strong>DailyStatus</strong>
        <p class="project-meta">SaaS para registro e acompanhamento diário de status de trabalho, com foco em visibilidade operacional e alinhamento de equipes.</p>
        <div class="project-actions">
          <a class="project-link" href="https://www.dailystatus.com.br" target="_blank" rel="noreferrer">Abrir produto</a>
        </div>
      </li>
      <li class="project-card">
        <strong>production-failure-not-about-performance</strong>
        <p class="project-meta">Simulação de falha em cascata causada por retry agressivo. Este projeto existe como artefato prático do estudo de caso publicado no blog.</p>
        <div class="project-actions">
          <a class="project-link" href={`${basePath}blog/o-dia-em-que-performance-nao-era-o-problema/`}>Ler estudo de caso</a>
        </div>
      </li>
    </ul>
    <a class="home" href={basePath}>Voltar para início</a>
  </section>
</SiteLayout>
