---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Projects | Rodrigo Santos Tech</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #07101d;
        --line: rgba(116, 160, 224, 0.34);
        --ink: #ecf4ff;
        --accent: #36d2ff;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 14%, rgba(54, 210, 255, 0.16) 0%, transparent 30%),
          linear-gradient(120deg, rgba(9, 28, 48, 0.96) 0%, rgba(4, 11, 19, 1) 55%, rgba(7, 16, 29, 1) 100%),
          var(--bg);
      }

      main {
        width: min(760px, 92vw);
        margin: 0 auto;
        padding: 2.8rem 0 4rem;
      }

      .shell {
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(10, 24, 42, 0.86);
        padding: 1.8rem;
      }

      h1 {
        font-family: "Chakra Petch", sans-serif;
        margin: 0;
        font-size: clamp(1.9rem, 4.5vw, 2.8rem);
      }

      p, li {
        color: #d8e6f8;
        line-height: 1.75;
      }

      ul {
        margin: 0.8rem 0 0;
        padding-left: 1.2rem;
      }

      .home {
        display: inline-flex;
        margin-top: 1rem;
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <main>
      <section class="shell">
        <h1>Projects</h1>
        <p>Projetos que conectam conteúdo técnico com prática em código.</p>
        <ul>
          <li>
            <strong>production-failure-not-about-performance</strong>: simulação de falha em cascata causada por retry agressivo.
          </li>
        </ul>
        <a class="home" href={basePath}>Voltar para início</a>
      </section>
    </main>
  </body>
</html>
