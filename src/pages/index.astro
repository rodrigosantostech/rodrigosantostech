---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rodrigo Santos Tech</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #07101d;
        --bg-soft: #0d1b2f;
        --card: rgba(10, 24, 42, 0.86);
        --line: rgba(116, 160, 224, 0.34);
        --ink: #ecf4ff;
        --muted: #9eb5d4;
        --accent: #36d2ff;
        --accent-2: #ff9f4a;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 15% 18%, rgba(54, 210, 255, 0.23) 0%, transparent 33%),
          radial-gradient(circle at 80% 8%, rgba(255, 159, 74, 0.16) 0%, transparent 28%),
          linear-gradient(120deg, rgba(9, 28, 48, 0.96) 0%, rgba(4, 11, 19, 1) 55%, rgba(7, 16, 29, 1) 100%),
          var(--bg);
        min-height: 100vh;
      }

      main {
        width: min(980px, 92vw);
        margin: 0 auto;
        padding: 2.8rem 0 4rem;
      }

      .hero {
        border: 1px solid var(--line);
        background: linear-gradient(135deg, rgba(14, 34, 58, 0.96), rgba(7, 17, 30, 0.9));
        border-radius: 22px;
        padding: 2rem;
        position: relative;
        overflow: hidden;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: auto -10% -45% auto;
        width: 360px;
        height: 360px;
        background: radial-gradient(circle, rgba(54, 210, 255, 0.2), transparent 65%);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-block;
        font-family: "Chakra Petch", sans-serif;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: var(--accent);
        margin: 0 0 0.8rem;
      }

      h1 {
        font-family: "Chakra Petch", sans-serif;
        font-size: clamp(2rem, 5vw, 3.8rem);
        margin: 0;
        line-height: 1.04;
        max-width: 18ch;
      }

      .hero p {
        color: var(--muted);
        max-width: 62ch;
        margin: 0.9rem 0 0;
        font-size: 1.05rem;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        margin: 1.5rem 0 0;
      }

      nav a {
        color: var(--ink);
        text-decoration: none;
        font-weight: 600;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.55rem 0.9rem;
        transition: transform 150ms ease, border-color 150ms ease, color 150ms ease;
      }

      nav a:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px);
      }

      .section-title {
        font-family: "Chakra Petch", sans-serif;
        margin: 2.1rem 0 1rem;
        font-size: 1.25rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      ul {
        list-style: none;
        padding: 0;
        display: grid;
        gap: 1.05rem;
      }

      li {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        backdrop-filter: blur(2px);
        transition: transform 170ms ease, border-color 170ms ease, box-shadow 170ms ease;
      }

      li:hover {
        transform: translateY(-3px);
        border-color: rgba(54, 210, 255, 0.7);
        box-shadow: 0 12px 26px rgba(6, 13, 21, 0.42);
      }

      li a {
        color: #ffffff;
        text-decoration: none;
        font-size: 1.15rem;
        font-weight: 700;
        font-family: "Chakra Petch", sans-serif;
      }

      .meta {
        margin-top: 0.4rem;
        color: var(--muted);
        font-size: 0.96rem;
      }

      .date {
        margin-top: 0.5rem;
        color: var(--accent-2);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      @media (max-width: 640px) {
        .hero {
          padding: 1.5rem;
        }

        li a {
          line-height: 1.3;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">Rodrigo Santos Tech Journal</p>
        <h1>Engenharia de software real, sem filtro e sem glamourização.</h1>
        <p>
          Histórias de produção, decisões arquiteturais e lições práticas sobre confiabilidade em sistemas distribuídos.
        </p>

        <nav>
          <a href={`${basePath}about/`}>About</a>
          <a href={`${basePath}now/`}>Now</a>
          <a href={`${basePath}projects/`}>Projects</a>
        </nav>
      </section>

      <h2 class="section-title">Posts mais recentes</h2>

      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={`${basePath}blog/${post.slug}/`}>{post.data.title}</a>
              <div class="meta">{post.data.description}</div>
              <div class="date">
                {post.data.pubDate.toLocaleDateString("pt-BR", {
                  day: "2-digit",
                  month: "short",
                  year: "numeric"
                })}
              </div>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
