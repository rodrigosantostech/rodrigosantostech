---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = import.meta.env.BASE_URL;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rodrigo Santos Tech</title>
    <style>
      :root {
        --bg: #f6f8fa;
        --card: #ffffff;
        --ink: #182026;
        --muted: #4f5d6a;
        --accent: #0b5fff;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "Georgia", "Times New Roman", serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 10% 10%, #dce9ff 0%, transparent 45%),
          radial-gradient(circle at 90% 90%, #d7f0e6 0%, transparent 35%),
          var(--bg);
      }

      main {
        width: min(900px, 92vw);
        margin: 0 auto;
        padding: 3rem 0 4rem;
      }

      h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin-bottom: 0.8rem;
      }

      p {
        color: var(--muted);
        max-width: 68ch;
      }

      nav {
        display: flex;
        gap: 1rem;
        margin: 1.5rem 0 2.5rem;
      }

      nav a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
      }

      ul {
        list-style: none;
        padding: 0;
        display: grid;
        gap: 1rem;
      }

      li {
        background: var(--card);
        border: 1px solid #d9e1e8;
        border-radius: 12px;
        padding: 1rem 1.2rem;
      }

      li a {
        color: var(--ink);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 700;
      }

      .meta {
        margin-top: 0.4rem;
        color: var(--muted);
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Engenharia de Software em Produção</h1>
      <p>
        Blog técnico com foco em arquitetura, confiabilidade e decisões difíceis de engenharia.
      </p>

      <nav>
        <a href={`${base}about`}>About</a>
        <a href={`${base}now`}>Now</a>
        <a href={`${base}projects`}>Projects</a>
      </nav>

      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={`${base}blog/${post.slug}/`}>{post.data.title}</a>
              <div class="meta">{post.data.description}</div>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
